{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "predev": "dotenv -e .env.local -- tsx scripts/migrate-private-galleries.ts",
    "dev:turbo": "next dev",
    "prebuild": "tsx scripts/prebuild-db.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenv -e .env.local -- drizzle-kit push --force",
    "db:ensure-home": "tsx scripts/ensure-home-tables.ts",
    "db:migrate-sqlite": "dotenv -e .env.local -- tsx scripts/migrate-sqlite-to-postgres.ts",
    "db:backfill-medium": "dotenv -e .env.local -- tsx scripts/backfill-medium-series-id.ts",
    "db:backfill-artwork-series": "dotenv -e .env.local -- tsx scripts/backfill-artwork-series.ts",
    "db:ensure-medium-galleries": "dotenv -e .env.local -- tsx scripts/ensure-medium-galleries.ts",
    "db:ensure-private-galleries": "dotenv -e .env.local -- tsx scripts/migrate-private-galleries.ts",
    "db:backup": "mkdir -p data/backups && cp data/site.db \"data/backups/site-$(date +%Y%m%d-%H%M%S).db\" && echo \"Backed up to data/backups/\"",
    "db:studio": "drizzle-kit studio",
    "seed": "dotenv -e .env.local -- tsx scripts/seed.ts"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "image-size": "^2.0.2",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "nodemailer": "^9.0.0",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
