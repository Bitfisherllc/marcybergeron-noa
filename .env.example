# Copy to `.env.local` for local development.

# --- PostgreSQL (required for app + seed + drizzle-kit) ---
# Option B (typical): Railway → Postgres → Connect → Public Network → copy TCP URL here and on Vercel.
# Use the public host (*.proxy.rlwy.net). Do NOT use postgres.railway.internal (only works inside Railway).
# Option A (local Docker): `docker compose up -d` then:
# DATABASE_URL=postgresql://marcy:marcy@127.0.0.1:5432/marcy
DATABASE_URL=
# Optional: if Railway gives a separate public URL variable, you can use this instead:
# DATABASE_PUBLIC_URL=

# Optional: override live site URL for admin “Live Site” buttons (e.g. https://marcybergeron-noa.vercel.app)
# NEXT_PUBLIC_SITE_URL=

# Admin (required for /admin)
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-please-16chars-min

# Contact form email (free via Gmail SMTP — no Resend required)
# 1. Enable 2-Step Verification on the Gmail account you send from.
# 2. Google Account → Security → App passwords → create one for "Mail".
# 3. Use that 16-character password as SMTP_PASS (not your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bitfisherllc@gmail.com
SMTP_PASS=
CONTACT_OWNER_EMAIL=marcynoaart@gmail.com
CONTACT_TEST_EMAIL=bitfisherllc@gmail.com
CONTACT_TEST_EMAIL_ENABLED=true
# Set CONTACT_TEST_EMAIL_ENABLED=false when you no longer want test copies.
# Optional display name / from address (defaults to SMTP_USER):
# CONTACT_FROM_EMAIL="Marcy Bergeron-Noa <bitfisherllc@gmail.com>"

# Image uploads on Vercel (admin slideshow, series, artwork, posts)
# Vercel → Storage → Blob → create with **Public** access → connect to project.
# Private Blob stores will not work — images must be publicly viewable on the site.

# Notes
# - Apply schema: `npm run db:push` (loads `.env.local` via dotenv-cli — set DATABASE_URL there first).
# - Copy data from old SQLite `data/site.db` once: `npm run db:migrate-sqlite` (with DATABASE_URL set).
# - Fresh seed from Wix CDN: `npm run seed` (with DATABASE_URL set).
# - `data/site.db` is optional legacy storage for migration only; the running app uses Postgres only.
